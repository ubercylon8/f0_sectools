# Per-platform credentials for the Wazuh MCP server.
#
# Copy this file to `.env.wazuh` and fill in real values. The `.env.wazuh` file
# is gitignored and MUST NEVER be committed. Credentials are loaded only by the
# Wazuh server, are never logged, never returned in tool output, and never sent
# to the model.

# Wazuh API endpoint (your self-hosted manager).
WAZUH_API_URL=https://wazuh.example.local:55000

# API user / password (use a dedicated read-only account where possible).
WAZUH_API_USER=
WAZUH_API_PASSWORD=

# Verify TLS certificate of the Wazuh API (set to false only for lab/self-signed).
WAZUH_VERIFY_TLS=true

# Read-only by default. Wazuh has no gated write actions today; if any are added,
# they will require this flag set to true AND a per-action confirmation token.
# WAZUH_ALLOW_WRITE=false
