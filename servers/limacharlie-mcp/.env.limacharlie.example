# LimaCharlie credentials for the f0_sectools LimaCharlie MCP server.
#
# Copy this file to `.env.limacharlie` (gitignored) and fill in real values.
# Credentials are loaded only by this server, never logged, never returned in
# tool output, never passed to the model, and never leave the host.

# Organization ID (OID) of the LimaCharlie org to read.
LIMACHARLIE_OID=

# A LimaCharlie API key with READ access. Prefer a dedicated, least-privilege
# key scoped to the read permissions the tools need (sensors, D&R rules,
# detections/insight, LCQL query). An org "secret" API key works; a scoped key
# is better.
LIMACHARLIE_API_KEY=

# Optional: user ID (UID) if using a user-scoped API key instead of an org key.
# LIMACHARLIE_UID=

# Read-only by default. No write/response actions are exposed yet. If any are
# added later (e.g. isolate sensor), they will require this flag set to true
# AND a per-action confirmation token.
# LIMACHARLIE_ALLOW_WRITE=false
