# ProjectAchilles credentials for the f0_sectools ProjectAchilles MCP server.
#
# Copy this file to `.env.projectachilles` (gitignored) and fill in real values.
# Credentials are loaded only by this server, never logged, never returned in
# tool output, never passed to the model, and never leave the host.

# Your ProjectAchilles instance base URL (no trailing /api — the server adds it).
PROJECTACHILLES_BASE_URL=https://tpsgl.projectachilles.io

# A ProjectAchilles API key (Settings → API Keys → Generate). Use the
# **read** scope ("analytics, results, agents — read-only"). The key starts with
# `pa_`. The organization is embedded in the key, so no org ID is needed.
PROJECTACHILLES_API_KEY=

# Verify TLS (leave true; set false only for a self-signed lab instance).
PROJECTACHILLES_VERIFY_TLS=true

# Read-only by default. No write actions are exposed (a read-scope key cannot
# write anyway). Reserved for future gated actions.
# PROJECTACHILLES_ALLOW_WRITE=false
