# ProjectAchilles credentials for the f0_sectools ProjectAchilles MCP server.
#
# Copy this file to `.env.projectachilles` (gitignored) and fill in real values.
# Credentials are loaded only by this server, never logged, never returned in
# tool output, never passed to the model, and never leave the host.

# Your ProjectAchilles API base URL (no trailing /api — the server adds it).
# NOTE: the API runs on the `agent` subdomain, NOT the web-UI host. For the org
# whose UI is https://<org>.projectachilles.io, the API base is:
PROJECTACHILLES_BASE_URL=https://<org>.agent.projectachilles.io

# A ProjectAchilles API key (Settings → API Keys → Generate). Use the
# **read** scope ("analytics, results, agents — read-only"). The key starts with
# `pa_`. The organization is embedded in the key, so no org ID is needed.
PROJECTACHILLES_API_KEY=

# Verify TLS (leave true; set false only for a self-signed lab instance).
PROJECTACHILLES_VERIFY_TLS=true

# Gated writes (the projectachilles-actions server: run/schedule/pause/cancel
# tests). Requires BOTH this flag AND a **read-write**-scope pa_ key (a
# read-only key 403s on every write). Each action also needs a fresh
# single-use confirmation token from scripts/confirm_action.py
# (--platform projectachilles). Leave false unless you use the actions server.
PROJECTACHILLES_ALLOW_WRITE=false

# Optional overrides for the gated-action audit trail.
# PROJECTACHILLES_AUDIT_LOG_PATH=audit-logs/actions.log
# PROJECTACHILLES_AUDIT_ACTOR=mcp-operator
