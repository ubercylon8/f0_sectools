# Microsoft Entra ID credentials for the f0_sectools Entra MCP server.
#
# Copy this file to `.env.entra` (gitignored) and fill in real values.
# Credentials are loaded only by this server, never logged, never returned in
# tool output, never passed to the model, and never leave the host.
# One Azure app registration may serve both this server and the Defender server.

ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# Verify TLS on the Graph API (leave true; set false only for lab proxies).
ENTRA_VERIFY_TLS=true

# ── Required Microsoft Graph application permissions (admin consent), read-only ──
#   Directory.Read.All               directory objects (existing)
#   Policy.Read.All                  conditional access policies (existing)
#   UserAuthenticationMethod.Read.All  auth-method registration (existing)
#   RoleManagement.Read.Directory    role assignments / privileged roles (existing)
#   AuditLog.Read.All                sign-in + directory audit logs (recommended)
#   IdentityRiskyUser.Read.All       Identity Protection risky users (recommended)
#   IdentityRiskEvent.Read.All       Identity Protection risk detections (recommended)
#
# Licensing: IdentityRiskyUser/IdentityRiskEvent require Microsoft Entra ID P2.
# Tools degrade gracefully — a missing permission/license returns a posture
# "finding" naming what to grant, rather than failing.
#
# Optional (tier 2): Application.Read.All, IdentityRiskyServicePrincipal.Read.All,
#   Reports.Read.All, Device.Read.All, DeviceManagementManagedDevices.Read.All
