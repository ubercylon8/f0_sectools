# Microsoft Defender XDR credentials for the f0_sectools Defender MCP server.
#
# Copy this file to `.env.defender` (gitignored) and fill in real values.
# Credentials are loaded only by this server, never logged, never returned in
# tool output, never passed to the model, and never leave the host.
# One Azure app registration may serve both this server and the Entra server.

DEFENDER_TENANT_ID=
DEFENDER_CLIENT_ID=
DEFENDER_CLIENT_SECRET=

# Verify TLS on the Graph API (leave true; set false only for lab proxies).
DEFENDER_VERIFY_TLS=true

# ── Required Microsoft Graph application permissions (admin consent), read-only ──
#   SecurityIncident.Read.All   incidents (correlated alert groups) — primary SOC unit
#   SecurityAlert.Read.All      alerts (alerts_v2, Defender XDR unified alerts)
#   ThreatHunting.Read.All      advanced hunting (runHuntingQuery, last 30d of events)
#   SecurityEvents.Read.All     secure score + control profiles (legacy security API)
#
# Licensing: incidents, alerts_v2, and hunting require Microsoft Defender (XDR)
# licensing. Tools degrade gracefully — a missing permission/license returns a
# posture "finding" telling you what to grant, rather than failing.

# ── Gated write actions (isolate_host / release_host) ─────────────────
# Writes are DISABLED unless this is exactly "true". Even then, each action
# additionally requires human confirmation: by default the operator approves
# it in `python scripts/confirm_action.py --watch`; alternatively
# scripts/confirm_action.py prints a one-shot token.
DEFENDER_ALLOW_WRITE=false
# F0_GATING_DIR=~/.f0sectools/gating  (shared gating-state dir override)
# Recorded as the actor in audit-logs/actions.log (application context has no
# signed-in user). Optional.
DEFENDER_AUDIT_ACTOR=mcp-operator
# Optional. Overrides the default audit log path (audit-logs/actions.log).
# DEFENDER_AUDIT_LOG_PATH=audit-logs/actions.log
# Requires the WindowsDefenderATP application permission Machine.Isolate
# (admin consent) for the isolate/release APIs on api.security.microsoft.com.
